{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@arac/types": ["./packages/ts/types/src/index.ts"],
      "@arac/ui": ["./packages/ts/ui/src/index.ts"],
      "@arac/config": ["./packages/ts/config/src/index.ts"]
    }
  }
}
