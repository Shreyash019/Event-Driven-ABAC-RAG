{
  "name": "go-shared",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "tags": ["type:lib", "lang:go"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": { "command": "go build ./...", "cwd": "packages/go" },
      "cache": true
    },
    "test": {
      "executor": "nx:run-commands",
      "options": { "command": "go test ./...", "cwd": "packages/go" },
      "cache": true
    }
  }
}
