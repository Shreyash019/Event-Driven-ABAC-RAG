// auth-service user store (system of record). Sessions/refresh tokens live in Redis,
// not here — this schema holds durable identities only (loc-doc/AuthService.md §3.6).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  DISABLED
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique // stored lowercased; the login lookup normalizes too
  name         String
  passwordHash String // argon2id; never the plaintext (GUARDRAILS §6.1)
  // ABAC attributes signed into the access token — server-side source of truth (§1.3).
  tenant       String
  department   String
  clearance    Int
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([tenant])
}
