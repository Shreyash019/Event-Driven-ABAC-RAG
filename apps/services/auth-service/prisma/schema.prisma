// auth-service user store (system of record). Sessions/refresh tokens live in Redis,
// not here — this schema holds durable identities only (loc-doc/AuthService.md §3.6).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  DISABLED
}

// Company-wide role ladder inside a department (the ABAC in-department rank). Ordinal by
// declaration order: MANAGER and above inherit visibility of the department's descendants
// (expanded into claims at token-mint). Replaces the old `isManager` boolean.
enum DeptRank {
  IC
  LEAD
  MANAGER
  SENIOR_MANAGER
  DIRECTOR
  VP
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique // stored lowercased; the login lookup normalizes too
  name         String
  passwordHash String // argon2id; never the plaintext (GUARDRAILS §6.1)
  // ABAC attributes signed into the access token — server-side source of truth (§1.3).
  tenant       String
  department   String
  clearance    Int
  // Company-wide seniority level (ordinal): L3 = intern (floor), higher = more senior.
  // Org axis, signed into the token — gates document `minLevel` and RBAC `Permission.minLevel`.
  level        Int        @default(3)
  status       UserStatus @default(ACTIVE)
  roles        UserRole[]
  departments  UserDepartment[]
  compartments UserCompartment[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([tenant])
}

// ---------------------------------------------------------------------------
// Org model (ABAC data axis) — departments tree, memberships, compartments.
// Governs DOCUMENT visibility (separate from RBAC). See loc-doc/OrgModel.md.
// ---------------------------------------------------------------------------

// A department in the company org tree. `slug` is the stable key used in JWT claims and
// the document security matrix (e.g. "finance", "finance.ap"); ids stay internal.
model Department {
  id       String           @id @default(cuid())
  tenant   String
  slug     String
  name     String
  parentId String?
  parent   Department?      @relation("DeptTree", fields: [parentId], references: [id])
  children Department[]     @relation("DeptTree")
  members  UserDepartment[]

  @@unique([tenant, slug])
  @@index([parentId])
}

// Membership of a user in a department. `rank` is the in-department role ladder; a rank of
// MANAGER or above ⇒ the user inherits visibility of the department's descendants (expanded
// into claims at token-mint).
model UserDepartment {
  userId       String
  departmentId String
  rank         DeptRank   @default(IC)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@id([userId, departmentId])
  @@index([departmentId])
}

// A need-to-know compartment tag, orthogonal to clearance (e.g. "M&A", "PII").
model Compartment {
  id     String            @id @default(cuid())
  tenant String
  key    String
  name   String
  users  UserCompartment[]

  @@unique([tenant, key])
}

model UserCompartment {
  userId        String
  compartmentId String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  compartment   Compartment @relation(fields: [compartmentId], references: [id], onDelete: Cascade)

  @@id([userId, compartmentId])
  @@index([compartmentId])
}

// ---------------------------------------------------------------------------
// RBAC (authorization) — separate from ABAC (data access). DB-managed so roles
// and their permissions can be edited at runtime; checks resolve from here.
// ---------------------------------------------------------------------------

// A fine-grained capability. Code checks permissions, never role names.
model Permission {
  id          String           @id @default(cuid())
  key         String           @unique // e.g. "users:read"
  description String
  // Org-level floor (Stage 1 of the combined gate): a user must have `level` >= this to
  // exercise the permission, checked BEFORE the role/scope grant. Default 3 (L3) = open to
  // everyone; raise it to reserve a capability for more senior levels.
  minLevel    Int              @default(3)
  roles       RolePermission[]
}

// A named bundle of permissions. `parent` gives hierarchy: a role inherits all
// of its ancestors' permissions (sub-roles).
model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  description String
  parentId    String?
  parent      Role?            @relation("RoleHierarchy", fields: [parentId], references: [id])
  children    Role[]           @relation("RoleHierarchy")
  permissions RolePermission[]
  assignments UserRole[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

// Assigns a role to a user, scoped to a tenant/department. NULL scope = applies
// everywhere (e.g. super-admin). A scoped assignment limits the role's reach
// (e.g. dept-admin for tenant=acme, department=finance only).
model UserRole {
  id              String  @id @default(cuid())
  userId          String
  roleId          String
  scopeTenant     String? // null = all tenants
  scopeDepartment String? // null = all departments
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  role            Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, scopeTenant, scopeDepartment])
  @@index([userId])
}
