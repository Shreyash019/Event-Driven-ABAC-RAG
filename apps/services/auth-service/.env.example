# auth-service environment — PLACEHOLDERS ONLY.
# Copy to `.env` (git-ignored) and fill real values. NEVER commit secrets (GUARDRAILS §5.1/§5.2).
# Every var below is read by src/config/configuration.ts; required ones fail the boot if missing.

# --- Runtime ---------------------------------------------------------------
NODE_ENV=development
PORT=3000

# --- JWT / signing (RS256) -------------------------------------------------
# `iss` and `aud` claims. The gateway validates these; keep them in sync with infra/gateway/krakend.json.
JWT_ISSUER=https://auth.arac.local
JWT_AUDIENCE=arac-services

# Key id published in JWKS and stamped in each token header. Bump on key rotation.
JWT_KID=arac-auth-2026-01

# RS256 PRIVATE signing key (SECRET). Accepts: raw PEM, PEM with escaped \n, or base64-encoded PEM.
# Generate a keypair:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out jwt_private.pem
#   openssl pkey -in jwt_private.pem -pubout -out jwt_public.pem
# Put it on one line as base64 (easiest for .env):
#   JWT_PRIVATE_KEY=$(base64 -i jwt_private.pem)
JWT_PRIVATE_KEY=base64-encoded-rsa-private-key-pem

# OPTIONAL public key (PEM/base64). If unset it is derived from the private key for JWKS.
# JWT_PUBLIC_KEY=base64-encoded-rsa-public-key-pem

# Token lifetimes (seconds). Access short-lived; refresh long-lived + rotating.
ACCESS_TTL_SECONDS=900           # 15 minutes
REFRESH_TTL_SECONDS=1209600      # 14 days

# --- Seed users (PoC in-memory store) --------------------------------------
# Plaintext passwords for the seeded demo users. In production these are REQUIRED —
# the service refuses to boot if a seed user falls back to the dev default.
SEED_FINANCE_PASSWORD=changeme-dev-only
SEED_HR_PASSWORD=changeme-dev-only
SEED_ADMIN_PASSWORD=changeme-dev-only

# --- Datastores ------------------------------------------------------------
# Postgres = user store (system of record). Redis = refresh-token sessions (dedicated,
# NOT the ingestion broker). Hostnames are the compose service names.
DATABASE_URL=postgresql://auth:authpass@auth-postgres:5432/auth?schema=public
AUTH_REDIS_URL=redis://auth-redis:6379

# --- OpenAPI / Swagger docs ------------------------------------------------
# Toggle the Swagger UI. Unset → on outside production, off in production.
API_DOCS_ENABLED=true
API_DOCS_PATH=docs

# --- Auth cookies (BFF delivery) -------------------------------------------
# COOKIE_DOMAIN unset = host-only cookie (fine for local dev).
# COOKIE_DOMAIN=.arac.local
COOKIE_SECURE=true               # MUST be true in production (HTTPS only); set false only for local http
COOKIE_SAMESITE=lax              # lax | strict | none
