{
  "$schema": "https://www.krakend.io/schema/v3.json",
  "version": 3,
  "name": "arac-gateway",
  "port": 8080,
  "timeout": "30s",
  "cache_ttl": "300s",
  "output_encoding": "no-op",
  "extra_config": {
    "security/cors": {
      "allow_origins": ["http://localhost:3013", "http://localhost:3015"],
      "allow_methods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
      "allow_headers": ["Origin", "Authorization", "Content-Type", "Cookie"],
      "expose_headers": ["Content-Length"],
      "allow_credentials": true,
      "max_age": "12h"
    },
    "router": {
      "return_error_msg": true
    }
  },
  "endpoints": [
    {
      "endpoint": "/api/auth/login",
      "method": "POST",
      "input_headers": ["Content-Type"],
      "backend": [
        {
          "url_pattern": "/auth/login",
          "host": ["http://auth-service:3000"]
        }
      ]
    },
    {
      "endpoint": "/api/auth/signup",
      "method": "POST",
      "input_headers": ["Content-Type"],
      "backend": [
        {
          "url_pattern": "/auth/signup",
          "host": ["http://auth-service:3000"]
        }
      ]
    },
    {
      "endpoint": "/api/auth/change-password",
      "method": "POST",
      "input_headers": ["Content-Type", "Authorization", "Cookie"],
      "backend": [
        {
          "url_pattern": "/auth/change-password",
          "host": ["http://auth-service:3000"]
        }
      ]
    },
    {
      "endpoint": "/api/auth/refresh",
      "method": "POST",
      "input_headers": ["Content-Type", "Authorization", "Cookie"],
      "backend": [
        {
          "url_pattern": "/auth/refresh",
          "host": ["http://auth-service:3000"]
        }
      ]
    },
    {
      "endpoint": "/api/auth/me",
      "method": "GET",
      "input_headers": ["Authorization", "Cookie"],
      "backend": [
        {
          "url_pattern": "/auth/me",
          "host": ["http://auth-service:3000"]
        }
      ]
    },
    {
      "endpoint": "/api/auth/logout",
      "method": "POST",
      "input_headers": ["Content-Type", "Authorization", "Cookie"],
      "backend": [
        {
          "url_pattern": "/auth/logout",
          "host": ["http://auth-service:3000"]
        }
      ]
    },
    {
      "endpoint": "/api/auth/logout-all",
      "method": "POST",
      "input_headers": ["Content-Type", "Authorization", "Cookie"],
      "backend": [
        {
          "url_pattern": "/auth/logout-all",
          "host": ["http://auth-service:3000"]
        }
      ]
    },
    {
      "endpoint": "/api/rag/query",
      "method": "POST",
      "input_headers": ["Content-Type", "Authorization"],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://auth-service:3000/.well-known/jwks.json",
          "disable_jwk_security": true,
          "propagate_claims": [
            ["sub", "X-Identity-Subject"],
            ["tenant", "X-Identity-Tenant"],
            ["department", "X-Identity-Department"],
            ["clearance", "X-Identity-Clearance"]
          ]
        }
      },
      "backend": [
        {
          "url_pattern": "/rag/query",
          "host": ["http://rag-gateway-service:8081"]
        }
      ]
    }
  ]
}
