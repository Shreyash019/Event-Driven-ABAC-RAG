{
  "$schema": "https://www.krakend.io/schema/v3.json",
  "version": 3,
  "name": "arac-gateway",
  "port": 8080,
  "timeout": "30s",
  "cache_ttl": "300s",
  "output_encoding": "no-op",
  "extra_config": {
    "security/cors": {
      "allow_origins": ["http://localhost:3000", "http://localhost:3001"],
      "allow_methods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
      "allow_headers": ["Origin", "Authorization", "Content-Type"],
      "expose_headers": ["Content-Length"],
      "max_age": "12h"
    },
    "router": {
      "return_error_msg": true
    }
  },
  "endpoints": [
    {
      "endpoint": "/api/auth/login",
      "method": "POST",
      "input_headers": ["Content-Type"],
      "backend": [
        {
          "url_pattern": "/auth/login",
          "host": ["http://host.docker.internal:3000"]
        }
      ]
    },
    {
      "endpoint": "/api/auth/refresh",
      "method": "POST",
      "input_headers": ["Content-Type", "Authorization"],
      "backend": [
        {
          "url_pattern": "/auth/refresh",
          "host": ["http://host.docker.internal:3000"]
        }
      ]
    },
    {
      "endpoint": "/api/rag/query",
      "method": "POST",
      "input_headers": ["Content-Type", "Authorization"],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://host.docker.internal:3000/.well-known/jwks.json",
          "disable_jwk_security": true,
          "propagate_claims": [
            ["sub", "X-Identity-Subject"],
            ["tenant", "X-Identity-Tenant"],
            ["department", "X-Identity-Department"],
            ["clearance", "X-Identity-Clearance"]
          ]
        }
      },
      "backend": [
        {
          "url_pattern": "/rag/query",
          "host": ["http://host.docker.internal:8081"]
        }
      ]
    }
  ]
}
